generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Dataset {
  id         String          @id @default(cuid())
  name       String
  edition    String
  version    String
  source     String
  license    String
  checksum   String
  importedAt DateTime        @default(now())
  sessions   ImportSession[]
}

model ImportSession {
  id            String   @id @default(cuid())
  datasetId     String
  dataset       Dataset  @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  startedAt     DateTime
  completedAt   DateTime
  status        String
  durationMs    Int
  warnings      String[]
  errors        String[]
  memoryUsageMb Float
}

model Surah {
  id              String       @id @default(cuid())
  number          Int          @unique
  arabicName      String
  transliteration String
  englishName     String
  revelationType  String
  totalVerses     Int
  verses          QuranVerse[]
}

model QuranVerse {
  id              String             @id @default(cuid())
  globalIndex     Int                @unique
  surahNumber     Int
  surah           Surah              @relation(fields: [surahNumber], references: [number], onDelete: Cascade)
  ayahNumber      Int
  arabicText      String
  arabicCleaned   String
  transliteration String
  translations    QuranTranslation[]

  @@unique([surahNumber, ayahNumber])
  @@index([surahNumber, ayahNumber])
}

model QuranTranslation {
  id         String     @id @default(cuid())
  verseId    String
  verse      QuranVerse @relation(fields: [verseId], references: [id], onDelete: Cascade)
  language   String
  translator String
  text       String

  @@index([verseId, language])
}

model HadithCollection {
  id                  String       @id @default(cuid())
  slug                String       @unique // e.g. "sahih-al-bukhari"
  shortName           String       // e.g. "Bukhari"
  displayName         String       // e.g. "Sahih al-Bukhari"
  titleArabic         String
  titleEnglish        String
  authorArabic        String
  authorEnglish       String
  introductionArabic  String
  introductionEnglish String
  totalHadiths        Int
  books               HadithBook[]
  hadiths             Hadith[]
}

model HadithBook {
  id               String           @id @default(cuid())
  collectionId     String
  collection       HadithCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  bookNumber       Int
  titleArabic      String
  titleEnglish     String
  chapters         HadithChapter[]
  hadiths          Hadith[]
}

model HadithChapter {
  id            String        @id @default(cuid())
  bookId        String
  book          HadithBook    @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapterNumber Int
  titleArabic   String
  titleEnglish  String
  hadiths       Hadith[]
}

model Hadith {
  id              String           @id @default(cuid())
  collectionId    String
  collection      HadithCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  bookId          String
  book            HadithBook       @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapterId       String
  chapter         HadithChapter    @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  hadithNumber    Int              // Sequential number in the database
  canonicalNumber String?          // Global numbering (e.g. Fath al-Bari index)
  originalNumber  String?          // Original dataset file numbering
  arabicText      String
  arabicCleaned   String
  englishNarrator String
  englishText     String

  @@index([collectionId, hadithNumber])
}
